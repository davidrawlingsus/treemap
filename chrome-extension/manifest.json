{
  "manifest_version": 3,
  "name": "MapTheGap Founder Extension",
  "version": "1.1.0",
  "description": "Import ads from Meta Ads Library into MapTheGap with one click.",
  "permissions": ["activeTab", "storage", "sidePanel"],
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "host_permissions": [
    "https://www.facebook.com/ads/library/*",
    "https://api.mapthegap.ai/*",
    "https://vizualizd.mapthegap.ai/*",
    "http://localhost:8000/*",
    "http://localhost:3000/*",
    "https://*/*"
  ],
  "content_scripts": [
    {
      "matches": ["*://www.facebook.com/ads/library/*"],
      "js": ["content/extractor.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["*://www.facebook.com/*"],
      "js": ["content/page-downloader.js"],
      "run_at": "document_idle",
      "world": "MAIN"
    },
    {
      "matches": [
        "*://vizualizd.mapthegap.ai/*",
        "*://localhost/*"
      ],
      "js": ["content/auth-listener.js"],
      "run_at": "document_idle"
    }
  ],
  "side_panel": {
    "default_path": "popup/popup.html"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
